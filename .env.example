# Redes sociales y mapa (copiar a .env.local y rellenar)
# URL pública del sitio (para canonical, OG, sitemap). Ej: https://www.aionautomations.com
NEXT_PUBLIC_SITE_URL=
# Teléfono para "Llámanos" (ej: 52 55 1234 5678)
NEXT_PUBLIC_PHONE=
# WhatsApp: código país + número sin + (ej: 5215512345678)
NEXT_PUBLIC_WHATSAPP_NUMBER=
# Instagram: URL de tu perfil
NEXT_PUBLIC_INSTAGRAM_URL=https://instagram.com/tu_usuario
# Facebook: URL de tu página
NEXT_PUBLIC_FACEBOOK_PAGE_URL=https://www.facebook.com/tu_pagina
# Google Maps: URL del iframe (Compartir > Insertar un mapa) y enlace para botón "Abrir en Maps"
NEXT_PUBLIC_GOOGLE_MAPS_EMBED_URL=
NEXT_PUBLIC_GOOGLE_MAPS_PLACE_URL=
