# URL pública del sitio (para canonical, OG, sitemap). Ej: https://www.aionautomations.com
NEXT_PUBLIC_SITE_URL=

# Teléfono para "Llámanos" (ej: 52 55 1234 5678)
NEXT_PUBLIC_PHONE=

# WhatsApp:  + número sin + (ej: 5215512345678)
NEXT_PUBLIC_WHATSAPP_NUMBER=523411687566

# Instagram: URL de tu perfil (ej: https://instagram.com/tu_usuario)
NEXT_PUBLIC_INSTAGRAM_URL=https://www.instagram.com/aionautomations/

# Facebook: URL de tu página (ej: https://www.facebook.com/tu_pagina)
NEXT_PUBLIC_FACEBOOK_PAGE_URL=https://www.facebook.com/share/18bgMhX2eC/?mibextid=wwXIfr

# Google Maps: URL del iframe (Compartir > Insertar un mapa)
NEXT_PUBLIC_GOOGLE_MAPS_EMBED_URL=

# Google Maps: enlace para botón "Abrir en Maps"
NEXT_PUBLIC_GOOGLE_MAPS_PLACE_URL=
